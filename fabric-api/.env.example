# Public URL of the Vite app (no trailing slash). Needed for QR codes phone scanners can open.
# Copy to .env and set to your laptop LAN IP (same host you use for npm run dev -- --host).
FRONTEND_URL=http://192.168.1.3:5173

# Required for /auth/register, /auth/login, and protected POST /create, /transfer, /location
JWT_SECRET=change-me-to-a-long-random-string
