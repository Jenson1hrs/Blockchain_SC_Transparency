# Public URL of the Vite app (no trailing slash). Used for all QR verify links.
# Phone QR testing: your laptop LAN IP, e.g. http://192.168.1.9:5173 (npm run dev -- --host)
# Laptop-only testing: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Required for /auth/register, /auth/login, and protected POST /create, /transfer, /location
JWT_SECRET=change-me-to-a-long-random-string

# QR verification hash (generate + verify). Use a long random string in production.
QR_SECRET=replace_with_secure_random_secret
